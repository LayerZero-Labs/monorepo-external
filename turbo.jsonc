{
    "$schema": "https://turborepo.org/schema.json",
    "daemon": false,
    "globalPassThroughEnv": [
        // COREPACK_HOME is required to enable corepack in stargate, otherwise
        // vercel CLI is unable to parse turbo version from package.json, then
        // decides not to enable corepack, in the fallback decides to use pnpm 9
        // based on the Vercel project age, and ultimately fails with
        // `ERR_PNPM_LOCKFILE_CONFIG_MISMATCH`.
        "COREPACK_HOME",

        "NPM_TOKEN",
        "VSCODE_INSPECTOR_OPTIONS",
        "CONFIG_PATH",
        "GITHUB_TOKEN",
        "REPO_SSH_KEY_*",
        "CI",
        "GITHUB_ACTIONS",
        "GITHUB_EVENT_NAME",
        "GITHUB_EVENT_ACTION",
        "GITHUB_EVENT_LABEL_NAME",
        "GITHUB_EVENT_SENDER",
        "SECURITY_TEAM_READ_TOKEN",
        "ACTIONS_CACHE_URL",
        "ACTIONS_RUNTIME_TOKEN",
        "VM_TOOLING_REGISTRY",
        "VM_TOOLING_IMAGE_DIRECTORY",
        "VM_TOOLING_LOCAL",
        "DOCKER_DEFAULT_PLATFORM",
        "VITEST",
        "VERCEL",
        "VERCEL_*"
    ],
    "tasks": {
        "test": {
            "inputs": ["$TURBO_DEFAULT$", "!**/*.md", "!**/LICENSE"],
            "outputs": [],
            "dependsOn": ["build"],
            "outputLogs": "new-only"
        },
        "clean": {
            "cache": false
        },
        "lint": {
            "inputs": ["$TURBO_DEFAULT$", "!**/*.md", "!**/LICENSE"],
            "outputs": [],
            "dependsOn": ["build"],
            "outputLogs": "new-only"
        },
        "build": {
            "inputs": ["$TURBO_DEFAULT$", "!**/*.md", "!**/LICENSE"],
            "outputs": [
                // ts build output
                "dist/**",

                // factory builder
                "src/lz_di_implGetter.ts",

                // evm, tron, zk
                "artifacts/**",
                "artifacts-*/**",

                // evm, tron, zk, starknet, ton
                "src/generated/**",
                "src/generated-*/**",

                // solana, stellar, starknet
                "target/**",
                "!target/incremental/**",
                "!target/*/incremental/**",

                // sui, iota, ton, aptos
                "build/**",

                // sui
                "dependencies/**",

                "src/typechain/**"
            ],
            "dependsOn": ["^build"],
            "outputLogs": "new-only"
        },
        "typecheck": {
            "cache": false,
            "outputs": [],
            "dependsOn": ["build"],
            "outputLogs": "new-only"
        },
        "test:integration": {
            "outputs": ["coverage/**"],
            "dependsOn": ["build"],
            "outputLogs": "new-only",
            "env": [
                "TON_MAINNET_API_URL",
                "TON_MAINNET_API_KEY",
                "SOLANA_MAINNET_RPC_URL",
                "AORI_API_KEY",
                "MATCHA_API_KEY",
                "TRON_WEB_MAINNET_RPC_URL",
                "AORI_API_URL",
                "STARGATE_API_KEY"
            ]
        },
        "dev": {
            "cache": false
        },
        "test:snapshot:check": {
            "cache": false,
            "dependsOn": ["build"],
            "outputLogs": "new-only",
            "passThroughEnv": ["TURBO_SNAPSHOT_FAILURE_REPORT_DIR"]
        },
        "test:snapshot:update": {
            "cache": false,
            "dependsOn": ["build"],
            "outputLogs": "new-only"
        }
    }
}
