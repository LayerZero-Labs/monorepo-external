{
    "name": "@layerzerolabs/nexus-evm-contracts",
    "version": "0.0.0",
    "private": true,
    "description": "LayerZero Labs Nexus EVM implementation",
    "license": "MIT",
    "scripts": {
        "build": "pnpm compile:evm && pnpm compile:zksync && pnpm compile:tron && pnpm flatten && pnpm contract-sizes",
        "clean": "rm -rf ./node_modules .turbo ./dist artifacts* hh-cache* cache out",
        "compile:evm": "pnpm lz-tool --env TS_NODE_COMPILER_OPTIONS='{\"module\":\"CommonJS\",\"moduleResolution\":\"node\"}' hardhat compile --config ./hardhat.config.js",
        "compile:tron": "pnpm lz-tool --env TS_NODE_COMPILER_OPTIONS='{\"module\":\"CommonJS\",\"moduleResolution\":\"node\"}' hardhat compile --config ./hardhat.config.js --network tron-mainnet",
        "compile:zksync": "pnpm lz-tool --env TS_NODE_COMPILER_OPTIONS='{\"module\":\"CommonJS\",\"moduleResolution\":\"node\"}' hardhat compile --config ./hardhat.config.js --network zksync-mainnet",
        "flatten": "pnpm exec lz-tool -e flatten_dir.sh hardhat ./contracts ./artifacts-flattened-contracts/contracts",
        "lint": "solhint --config solhint.config.js 'contracts/**/*.sol' 'test/**/*.sol' --fix --noPrompt",
        "test": "pnpm lz-tool --env FOUNDRY_PROFILE=test forge test"
    },
    "devDependencies": {
        "@layerzerolabs/contract-sizes-evm": "workspace:*",
        "@layerzerolabs/hardhat-tron": "catalog:",
        "@layerzerolabs/lz-evm-messagelib-v2": "catalog:console",
        "@layerzerolabs/lz-evm-protocol-v2": "catalog:console",
        "@layerzerolabs/lz-evm-v1-0.7": "catalog:console",
        "@layerzerolabs/oapp-evm-contracts": "catalog:console",
        "@layerzerolabs/oapp-upgradeable-evm-contracts": "catalog:console",
        "@layerzerolabs/oft-evm-contracts": "catalog:console",
        "@layerzerolabs/oft-upgradeable-evm-contracts": "catalog:console",
        "@layerzerolabs/solhint-configuration": "workspace:*",
        "@layerzerolabs/test-devtools-evm-foundry": "catalog:",
        "@layerzerolabs/test-utils-evm-contracts": "workspace:*",
        "@layerzerolabs/toolbox-foundry": "catalog:",
        "@layerzerolabs/tsup-configuration": "workspace:*",
        "@layerzerolabs/typescript-configuration": "workspace:*",
        "@layerzerolabs/utils-evm-contracts": "catalog:console",
        "@layerzerolabs/utils-upgradeable-evm-contracts": "catalog:console",
        "@layerzerolabs/vm-tooling-evm": "workspace:*",
        "@matterlabs/hardhat-zksync-solc": "catalog:console",
        "@openzeppelin/contracts": "catalog:console",
        "@openzeppelin/contracts-upgradeable": "catalog:console",
        "hardhat-deploy": "catalog:",
        "solhint": "catalog:"
    },
    "publishConfig": {
        "access": "restricted",
        "registry": "https://registry.npmjs.org/"
    }
}
